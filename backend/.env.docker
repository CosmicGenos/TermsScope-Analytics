
APP_NAME=TermsScope Analytics
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key


DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/termsscope
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@postgres:5432/termsscope


REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=86400


DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-5.4-2026-03-05

OPENAI_API_KEY=

GOOGLE_API_KEY=

ANTHROPIC_API_KEY=


GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback


FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]


RATE_LIMIT_PER_HOUR=10
MAX_TOKEN_LIMIT=100000
MAX_FILE_SIZE_MB=10
